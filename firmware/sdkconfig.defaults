# --- flash / partitions ---
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# --- build for size (no PSRAM: RAM and flash are both tight) ---
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# --- TLS: Mozilla CA bundle so *.icloud.com verifies without bundled certs ---
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
# iCloud sends full 16 KB TLS records, so keep the inbound content buffer at the
# max; shrink only the outbound side (our requests are small) to save heap.
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=16384
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=4096
# No PSRAM: the handshake must fit in ~35 KB of free heap. Dynamic buffers grow
# the RX buffer only as records arrive (instead of a static 16 KB up front) and
# free the CA cert + handshake config once the session is up. This is what makes
# the TLS connection to iCloud possible while Wi-Fi + LVGL are both resident.
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y
CONFIG_MBEDTLS_DYNAMIC_FREE_CA_CERT=y
CONFIG_MBEDTLS_DYNAMIC_FREE_CONFIG_DATA=y

# --- FatFs on SD: long filenames for state/*.map ---
CONFIG_FATFS_LFN_HEAP=y

# --- the sync runs in the main task; give it headroom ---
CONFIG_ESP_MAIN_TASK_STACK_SIZE=12288

# --- LVGL: monochrome theme for the PalmOS grayscale look ---
CONFIG_LV_USE_THEME_MONO=y
# Shrink LVGL's heap pool from the 64 KB default -- our UI (lists, buttons, a few
# labels) fits comfortably in 24 KB, and the freed 40 KB is what the TLS handshake
# + sync working set need. If the UI ever logs "lv_malloc failed", raise this.
CONFIG_LV_MEM_SIZE_KILOBYTES=24

# --- Wi-Fi: trim the (generous) default buffer pools to claw back heap for TLS.
# Sync is low-bandwidth, so fewer RX/TX buffers is fine. ---
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=4
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=16
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=16

# --- quieter default log level ---
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# --- power: automatic light-sleep for battery life (power.c) ---
# DFS + tickless idle let the SoC light-sleep during the idle delays between LVGL
# frames; power.c calls esp_pm_configure(light_sleep_enable). Wi-Fi/SD drivers
# hold PM locks while active so a sync is never interrupted. To disable
# light-sleep (e.g. if it disturbs touch/display on a given board), comment out
# these two lines and rebuild -- the PWM backlight + idle screen-off still work.
CONFIG_PM_ENABLE=y
CONFIG_FREERTOS_USE_TICKLESS_IDLE=y
