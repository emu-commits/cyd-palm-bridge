/* secrets.h -- copy to secrets.h and fill in. secrets.h is gitignored.
 *
 * DAV_PASS must be an iCloud APP-SPECIFIC password (appleid.apple.com >
 * Sign-In & Security > App-Specific Passwords), entered WITH its dashes; the
 * normal Apple ID password is blocked by 2FA.
 *
 * SYNC_COLL is a collection path WITHOUT leading/trailing slashes, as printed
 * by the host tool's `bridge_cli discover` (drop the leading '/'). Example for
 * a calendar:  21226414825/calendars/5515059C-5D36-4AD4-ACE7-D301519D3435
 */
#ifndef SECRETS_H
#define SECRETS_H

#define WIFI_SSID   "your-ssid"
#define WIFI_PASS   "your-wifi-password"

#define DAV_BASE    "https://caldav.icloud.com"   /* effective host resolved at boot */
#define DAV_USER    "you@icloud.com"
#define DAV_PASS    "xxxx-xxxx-xxxx-xxxx"

#define SYNC_COLL   "21226414825/calendars/REPLACE-WITH-CALENDAR-UUID"
#define SYNC_PDB    "/sdcard/DatebookDB.pdb"       /* Palm DB on the SD card */
#define SYNC_KIND   KIND_CAL                       /* KIND_CAL | KIND_TODO | KIND_CARD */

/* ---- multi-app HotSync (optional) ----------------------------------------
 * HotSync syncs the Date Book (SYNC_COLL above) plus, if configured here, the
 * To Do list and the Address book -- each to its OWN iCloud collection. Leave a
 * collection empty ("") to skip that app. Paths come from `bridge_cli discover`
 * (drop the leading '/'), exactly like SYNC_COLL.
 *
 * To Do  -> a Reminders LIST (a CalDAV collection of VTODOs, on the caldav host).
 * Address-> the iCloud address book (CardDAV, which lives on a SEPARATE host --
 *           contacts.icloud.com -- so DAV_CARD_BASE points there).
 * Memo has no CalDAV/CardDAV surface on iCloud (Notes isn't exposed), so it is
 * intentionally not synced. */
#define SYNC_TODO_COLL  ""                         /* e.g. 2122.../calendars/<reminders-list-uuid> */
#define SYNC_TODO_PDB   "/sdcard/ToDoDB.pdb"
#define SYNC_CARD_COLL  ""                         /* e.g. 2122.../carddavhome/card */
#define SYNC_CARD_PDB   "/sdcard/AddressDB.pdb"
#define DAV_CARD_BASE   "https://contacts.icloud.com"  /* CardDAV host (resolved to pNN- at boot) */

#endif
